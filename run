#!/usr/bin/env bash
# Auto-setup venv + run spx_tracking.py
set -euo pipefail
DIR="$(cd "$(dirname "$0")" && pwd)"
VENV="$DIR/.venv"
PYTHON="$VENV/bin/python"

if [ ! -x "$PYTHON" ]; then
    python3 -m venv "$VENV"
    "$VENV/bin/pip" install -q -r "$DIR/requirements.txt"
fi

exec "$PYTHON" "$DIR/skills/spx-tracking/scripts/spx_tracking.py" "$@"
